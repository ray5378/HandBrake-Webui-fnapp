#!/bin/bash

IMAGE_NAME="ray5378/handbrake-webui-fnapp:${TRIM_APPVER:-latest}"

start_container() {
  local vol_config="-v ${TRIM_PKGVAR}/config:/config"

  # Mount each accessible path directly at its original path
  if [ -n "${TRIM_DATA_ACCESSIBLE_PATHS}" ]; then
    IFS=':' read -ra PATHS <<< "${TRIM_DATA_ACCESSIBLE_PATHS}"
    for path in "${PATHS[@]}"; do
      if [ -n "$path" ] && [ -d "$path" ]; then
        vol_config="$vol_config -v ${path}:${path}:ro"
      fi
    done
  fi

  local dev_params=""
  [ -d /dev/dri ] && dev_params="--device /dev/dri:/dev/dri"

  docker rm -f handbrake-webui 2>/dev/null || true
  docker run -d \
    --name handbrake-webui \
    --restart unless-stopped \
    --network host \
    $vol_config \
    -e PORT="${TRIM_SERVICE_PORT:-52389}" \
    -e CONFIG_DIR=/config \
    -e NODE_ENV=production \
    -e TRIN_DATA_ACCESSIBLE_PATHS="${TRIM_DATA_ACCESSIBLE_PATHS:-}" \
    -e TRIN_APP_STATUS="${TRIM_APP_STATUS:-}" \
    $dev_params \
    $IMAGE_NAME
}

case $1 in
  start)
    start_container
    ;;
  stop)
    docker stop handbrake-webui 2>/dev/null || true
    docker rm handbrake-webui 2>/dev/null || true
    exit 0
    ;;
  status)
    docker inspect handbrake-webui | grep -q '"Status": "running",' || exit 3
    exit 0
    ;;
  *)
    exit 1
    ;;
esac