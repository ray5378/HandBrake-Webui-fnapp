#!/bin/bash

IMAGE_NAME="ray5378/handbrake-webui-fnapp:latest"

find_compose_file() {
  for c in "${TRIM_APPDEST}/docker/docker-compose.yaml" \
           "${TRIM_APPDEST}/target/docker/docker-compose.yaml"; do
    if [ -f "$c" ]; then
      echo "$c"
      return 0
    fi
  done
  return 1
}

inject_drive_volume() {
  local compose_file="$1"
  local path="$2"
  [ ! -f "$compose_file" ] && return 1

  # Save path for upgrade persistence
  if [ -n "$path" ]; then
    mkdir -p "${TRIM_PKGVAR}" 2>/dev/null || true
    echo "$path" > "${TRIM_PKGVAR}/drive_path" 2>/dev/null || true
  fi

  # Remove existing /drive/ volumes
  sed -i '\|^      - .*:/drive|d' "$compose_file" 2>/dev/null || true

  [ -z "$path" ] && return 0

  local name
  name=$(basename "$path" | tr -d '"')
  [ -z "$name" ] && return 0

  sed -i "/^    volumes:/a\\      - ${path}:/drive/${name}" "$compose_file"
}

load_docker_image() {
  local tar_path=""
  if [ -n "${TRIM_TEMP_TPKFILE}" ] && [ -f "${TRIM_TEMP_TPKFILE}/docker/image.tar.gz" ]; then
    tar_path="${TRIM_TEMP_TPKFILE}/docker/image.tar.gz"
  elif [ -n "${TRIM_APPDEST}" ] && [ -f "${TRIM_APPDEST}/../docker/image.tar.gz" ]; then
    tar_path="${TRIM_APPDEST}/../docker/image.tar.gz"
  else
    echo "Image tarball not found, will pull from registry on first start" >&2
    return 1
  fi

  if docker image inspect "${IMAGE_NAME}" &>/dev/null; then
    return 0
  fi

  gunzip -c "${tar_path}" | docker load
  docker tag handbrake-webui:latest "${IMAGE_NAME}" 2>/dev/null || true
  return 0
}

# Main
load_docker_image

COMPOSE_FILE=$(find_compose_file)
if [ -z "$COMPOSE_FILE" ]; then
  echo "docker-compose.yaml not found, volumes will not be injected" >&2
else
  # Use wizard-provided drive_path, fall back to file, fall back to TRIM_DATA_SHARE_PATHS
  local_path="${drive_path}"
  if [ -z "$local_path" ] && [ -f "${TRIM_PKGVAR}/drive_path" ]; then
    local_path=$(cat "${TRIM_PKGVAR}/drive_path")
  fi
  if [ -z "$local_path" ] && [ -n "${TRIM_DATA_SHARE_PATHS}" ]; then
    local_path="${TRIM_DATA_SHARE_PATHS%%:*}"
  fi
  inject_drive_volume "$COMPOSE_FILE" "$local_path"
fi

exit 0
